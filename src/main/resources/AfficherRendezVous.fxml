<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620" prefWidth="900"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controlers.RendezVousController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>

            <Label text="Rendez-Vous"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" prefWidth="180" promptText="Rechercher..."/>
            <ComboBox fx:id="filterStatut" prefWidth="150" promptText="Tous les statuts"/>
            <Button fx:id="btnAjouter" text="+ Nouveau" onAction="#ouvrirAjout"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.62">

            <!-- LEFT : Grid View -->
            <ScrollPane fitToWidth="true">
                <VBox>
                    <VBox.margin><Insets top="16" right="14" bottom="16" left="16"/></VBox.margin>
                    <Label text="Grille"/>
                    <GridPane fx:id="gridView" hgap="12" vgap="12"/>
                </VBox>
            </ScrollPane>

            <!-- RIGHT : List View + Actions -->
            <VBox spacing="10">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Label text="Liste"/>

                <ListView fx:id="listView" VBox.vgrow="ALWAYS"/>

                <Button fx:id="btnModifier" maxWidth="Infinity"
                        text="Modifier" onAction="#ouvrirModification"/>

                <Button fx:id="btnSupprimer" maxWidth="Infinity"
                        text="Supprimer" onAction="#supprimerRdv"/>

                <VBox fx:id="detailPane" spacing="5" visible="false">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    <Label text="DÉTAILS"/>
                    <Label fx:id="lblDetailPatient"/>
                    <Label fx:id="lblDetailDate"/>
                    <Label fx:id="lblDetailMotif" wrapText="true"/>
                    <Label fx:id="lblDetailLieu"/>
                    <Label fx:id="lblDetailStatut"/>
                </VBox>
            </VBox>

        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding><Insets top="8" right="20" bottom="8" left="20"/></padding>
            <Label fx:id="lblTotal" text="0 rendez-vous"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblStatus" text=""/>
        </HBox>
    </bottom>

</BorderPane>