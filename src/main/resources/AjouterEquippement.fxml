<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<BorderPane prefHeight="737.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.vita.Controlers.EquipementController">

    <stylesheets>
        <URL value="@styles/style.css" />
    </stylesheets>

    <!-- SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="6">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <Label text="VITA" styleClass="sidebar-title" />
            <Label text="Systeme de Gestion Hospitaliere"
                   style="-fx-text-fill:rgba(255,255,255,0.5);
                          -fx-font-size:11px; -fx-padding:0 10 12 10;" />
            <Separator style="-fx-background-color:rgba(255,255,255,0.12);" />
            <Label text="NAVIGATION" styleClass="sidebar-section" />
            <Button text="Tableau de bord" styleClass="nav-item"
                    onAction="#allerAuDashboard" maxWidth="Infinity" />
            <Button text="Espace Docteurs"  styleClass="nav-item" maxWidth="Infinity" />
            <Button text="Espace Patients"  styleClass="nav-item" maxWidth="Infinity" />
            <Button text="Rendez-vous"      styleClass="nav-item" maxWidth="Infinity" />
            <Button text="Comptes Rendus"   styleClass="nav-item" maxWidth="Infinity" />
            <Button text="Quiz"             styleClass="nav-item" maxWidth="Infinity" />
            <Button text="Evenements"       styleClass="nav-item" maxWidth="Infinity" />
            <Separator style="-fx-background-color:rgba(255,255,255,0.12);" />
            <Label text="INVENTAIRE" styleClass="sidebar-section" />
            <Button text="Medicaments"  styleClass="nav-item"
                    onAction="#allerAuxMedicaments" maxWidth="Infinity" />
            <Button text="Equipements"  styleClass="nav-subitem" maxWidth="Infinity" />
            <Button text="Commandes"    styleClass="nav-item"
                    onAction="#allerAuxCommandes"   maxWidth="Infinity" />
            <Region VBox.vgrow="ALWAYS" />
            <Label text="VITA v1.0 2025"
                   style="-fx-text-fill:rgba(255,255,255,0.28);
                          -fx-font-size:10px; -fx-padding:0 10;" />
        </VBox>
    </left>

    <center>
        <BorderPane>

            <!-- HEADER -->
            <top>
                <VBox styleClass="app-header" spacing="2">
                    <Label text="Equipements" styleClass="app-header-title" />
                    <Label text="Gestion du parc materiel hospitalier"
                           styleClass="app-header-subtitle" />
                </VBox>
            </top>

            <center>
                <VBox styleClass="page" spacing="14">

                    <!-- TOOLBAR -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="+ Ajouter"   onAction="#ajouterEquipement"
                                styleClass="button, btn-create" />
                        <Button text="Modifier"    onAction="#modifierEquipement"
                                styleClass="button, btn-edit" />
                        <Button text="Supprimer"   onAction="#supprimerEquipement"
                                styleClass="button, btn-delete" />
                        <Button text="Actualiser"  onAction="#chargerEquipements"
                                styleClass="button, btn-cancel" />
                        <Region HBox.hgrow="ALWAYS" />
                        <!-- Switch vue -->
                        <ToggleButton fx:id="btnVueTable" text="Tableau"
                                      onAction="#switchToTable" selected="true"
                                      style="-fx-background-color:#6b0d1e;
                                             -fx-text-fill:white;
                                             -fx-background-radius:8 0 0 8;
                                             -fx-padding:7 14;" />
                        <ToggleButton fx:id="btnVueCards" text="Cards"
                                      onAction="#switchToCards"
                                      style="-fx-background-radius:0 8 8 0;
                                             -fx-padding:7 14;" />
                        <Label fx:id="messageLabel" text=""
                               style="-fx-font-size:13px;" />
                    </HBox>

                    <!-- VUE TABLE -->
                    <TableView fx:id="equipementTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId"           text="ID"
                                         prefWidth="50"  />
                            <TableColumn fx:id="colNom"          text="Nom"
                                         prefWidth="140" />
                            <TableColumn fx:id="colType"         text="Type"
                                         prefWidth="110" />
                            <TableColumn fx:id="colMarque"       text="Marque"
                                         prefWidth="110" />
                            <TableColumn fx:id="colEtat"         text="Etat"
                                         prefWidth="120" />
                            <TableColumn fx:id="colLocalisation" text="Localisation"
                                         prefWidth="120" />
                            <TableColumn fx:id="colDate"         text="Acquisition"
                                         prefWidth="110" />
                        </columns>
                    </TableView>

                    <!-- VUE CARDS -->
                    <ScrollPane fitToWidth="true" visible="false"
                                managed="false" VBox.vgrow="ALWAYS"
                                style="-fx-background:transparent;
                                       -fx-background-color:transparent;">
                        <FlowPane fx:id="cardsPane" hgap="14" vgap="14"
                                  style="-fx-padding:8;" />
                    </ScrollPane>

                    <!-- FORMULAIRE -->
                    <VBox styleClass="form-card" spacing="10">
                        <Label text="Formulaire" styleClass="form-title" />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <VBox spacing="4">
                                <Label text="Nom" styleClass="label" />
                                <TextField fx:id="nomField"
                                           promptText="Nom equipement"
                                           styleClass="text-field"
                                           style="-fx-pref-width:130;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Description" styleClass="label" />
                                <TextField fx:id="descField"
                                           promptText="Description"
                                           styleClass="text-field"
                                           style="-fx-pref-width:130;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Type" styleClass="label" />
                                <TextField fx:id="typeField"
                                           promptText="Ex: Imagerie"
                                           styleClass="text-field"
                                           style="-fx-pref-width:100;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Marque" styleClass="label" />
                                <TextField fx:id="marqueField"
                                           promptText="Ex: Siemens"
                                           styleClass="text-field"
                                           style="-fx-pref-width:100;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Etat" styleClass="label" />
                                <ComboBox fx:id="etatCombo"
                                          styleClass="combo-box"
                                          style="-fx-pref-width:130;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Localisation" styleClass="label" />
                                <TextField fx:id="localisationField"
                                           promptText="Ex: Salle B12"
                                           styleClass="text-field"
                                           style="-fx-pref-width:110;" />
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Date acquisition" styleClass="label" />
                                <DatePicker fx:id="datePicker"
                                            style="-fx-pref-width:140;" />
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>
            </center>

            <!-- FOOTER -->
            <bottom>
                <HBox styleClass="statusbar" alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblTotal" text="0 equipement(s)"
                           styleClass="text-muted" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Systeme operationnel"
                           style="-fx-text-fill:#3B6D11; -fx-font-size:11px;" />
                </HBox>
            </bottom>

        </BorderPane>
    </center>

</BorderPane>