<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #f0ebf4; -fx-background: #f0ebf4;"
            xmlns="http://javafx.com/javafx/22"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controles.AjouterQuiz">

   <VBox spacing="16" style="-fx-background-color: #f0ebf4;">
      <padding><Insets top="30" bottom="30" left="60" right="60"/></padding>

      <!-- CARTE TITRE (style Google Forms) -->
      <VBox style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-border-width: 0 0 0 8;
                     -fx-border-color: #AD1457 transparent transparent transparent;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
         <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

         <Label text="Gestion des Questions"
                style="-fx-font-size: 26px; -fx-font-weight: bold;
                          -fx-text-fill: #6D1B3A;"/>
         <Label text="VitaSanté — Formulaire de création de question"
                style="-fx-font-size: 13px; -fx-text-fill: #888; -fx-padding: 4 0 0 0;"/>
      </VBox>

      <!-- CARTE ID -->
      <VBox style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
         <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
         <Label text="ID Question"
                style="-fx-font-size: 14px; -fx-text-fill: #333; -fx-font-weight: bold;"/>
         <TextField fx:id="txtId" editable="false" promptText="Auto-généré"
                    style="-fx-background-color: #f5f5f5;
                              -fx-border-color: transparent transparent #ccc transparent;
                              -fx-border-width: 0 0 2 0;
                              -fx-background-radius: 0;
                              -fx-font-size: 14px;
                              -fx-padding: 8 0 4 0;"/>
      </VBox>

      <!-- CARTE QUESTION -->
      <VBox style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
         <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
         <Label text="Question *"
                style="-fx-font-size: 14px; -fx-text-fill: #333; -fx-font-weight: bold;"/>
         <TextField fx:id="txtQuestion" promptText="Entrez votre question ici..."
                    style="-fx-border-color: transparent transparent #AD1457 transparent;
                              -fx-border-width: 0 0 2 0;
                              -fx-background-color: transparent;
                              -fx-font-size: 14px;
                              -fx-padding: 8 0 4 0;"/>
      </VBox>

      <!-- CARTE RÉPONSES -->
      <VBox spacing="14"
            style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
         <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>

         <Label text="Options de réponse"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

         <!-- Réponse A -->
         <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="A"
                   style="-fx-background-color: #AD1457;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-min-width: 28; -fx-min-height: 28;
                              -fx-alignment: center;
                              -fx-background-radius: 50;
                              -fx-font-size: 13px;"/>
            <TextField fx:id="txtA" promptText="Réponse A" HBox.hgrow="ALWAYS"
                       style="-fx-border-color: transparent transparent #ddd transparent;
                                  -fx-border-width: 0 0 1 0;
                                  -fx-background-color: transparent;
                                  -fx-font-size: 14px;
                                  -fx-padding: 6 0 4 0;"/>
         </HBox>

         <!-- Réponse B -->
         <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="B"
                   style="-fx-background-color: #AD1457;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-min-width: 28; -fx-min-height: 28;
                              -fx-alignment: center;
                              -fx-background-radius: 50;
                              -fx-font-size: 13px;"/>
            <TextField fx:id="txtB" promptText="Réponse B" HBox.hgrow="ALWAYS"
                       style="-fx-border-color: transparent transparent #ddd transparent;
                                  -fx-border-width: 0 0 1 0;
                                  -fx-background-color: transparent;
                                  -fx-font-size: 14px;
                                  -fx-padding: 6 0 4 0;"/>
         </HBox>

         <!-- Réponse C -->
         <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="C"
                   style="-fx-background-color: #AD1457;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-min-width: 28; -fx-min-height: 28;
                              -fx-alignment: center;
                              -fx-background-radius: 50;
                              -fx-font-size: 13px;"/>
            <TextField fx:id="txtC" promptText="Réponse C" HBox.hgrow="ALWAYS"
                       style="-fx-border-color: transparent transparent #ddd transparent;
                                  -fx-border-width: 0 0 1 0;
                                  -fx-background-color: transparent;
                                  -fx-font-size: 14px;
                                  -fx-padding: 6 0 4 0;"/>
         </HBox>

         <!-- Réponse D -->
         <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="D"
                   style="-fx-background-color: #AD1457;
                              -fx-text-fill: white;
                              -fx-font-weight: bold;
                              -fx-min-width: 28; -fx-min-height: 28;
                              -fx-alignment: center;
                              -fx-background-radius: 50;
                              -fx-font-size: 13px;"/>
            <TextField fx:id="txtD" promptText="Réponse D" HBox.hgrow="ALWAYS"
                       style="-fx-border-color: transparent transparent #ddd transparent;
                                  -fx-border-width: 0 0 1 0;
                                  -fx-background-color: transparent;
                                  -fx-font-size: 14px;
                                  -fx-padding: 6 0 4 0;"/>
         </HBox>
      </VBox>

      <!-- CARTE BONNE RÉPONSE -->
      <VBox style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
         <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
         <Label text="Bonne réponse *"
                style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
         <ComboBox fx:id="comboBonneRep" maxWidth="Infinity" promptText="Choisir la bonne réponse">
            <items>
               <FXCollections fx:factory="observableArrayList">
                  <String fx:value="A" />
                  <String fx:value="B" />
                  <String fx:value="C" />
                  <String fx:value="D" />
               </FXCollections>
            </items>
         </ComboBox>
      </VBox>

      <!-- CARTE BOUTONS -->
      <VBox style="-fx-background-color: white;
                     -fx-background-radius: 10;
                     -fx-border-color: #e0e0e0;
                     -fx-border-radius: 10;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
         <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
         <HBox spacing="12">
            <Button text="✔ Ajouter" onAction="#AjouterQuiz"
                    style="-fx-background-color: #AD1457; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
            <Button text="✎ Modifier" onAction="#ModifierQuiz"
                    style="-fx-background-color: #1565C0; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
            <Button text="✖ Supprimer" onAction="#SupprimerQuiz"
                    style="-fx-background-color: #C62828; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
            <Button fx:id="btnVider" text="↺ Vider" onAction="#viderAction"
                    style="-fx-background-color: #E0E0E0;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
         </HBox>
      </VBox>

   </VBox>
</ScrollPane>