<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="737.0" prefWidth="1100.0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlers.AfficherCompteRenduController">
    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="15" styleClass="sidebar">
            <Label styleClass="sidebar-title" text="VITA" />
            <Separator style="-fx-background-color: rgba(255,255,255,0.3);" />
            <Button styleClass="nav-item" text="Tableau de bord" />
            <Button styleClass="nav-item" text="Espace Docteurs" />
            <Button styleClass="nav-item" text="Espace Patients" />
            <Button onAction="#ConsulterRDV" styleClass="nav-item" text="Espace Rendez-vous" />
            <Button styleClass="nav-item-active" text="Les Comptes Rendus" />
            <Button styleClass="nav-item" text="Les Événements" />
            <Button styleClass="nav-item" text="Formulaire" />
            <Button styleClass="nav-item" text="Quiz" />
        </VBox>
    </left>

    <!-- MAIN : le center est swappé dynamiquement par le contrôleur -->
    <center>
        <BorderPane fx:id="mainPane">

            <!-- TOOLBAR -->
            <top>
                <VBox style="-fx-border-color: transparent transparent #ececec transparent;                              -fx-background-color: white;">

                    <!-- Ligne 1 : titre + boutons d'action -->
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-border-color: transparent; -fx-background-color: transparent;" styleClass="form-card">
                        <padding><Insets bottom="10" left="24" right="24" top="14" /></padding>
                        <Label fx:id="lblPageTitle" styleClass="page-title" text="Comptes Rendus" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnRetour" managed="false" onAction="#handleRetour" styleClass="button, btn-cancel" text="← Retour" visible="false" />
                        <Button onAction="#handleAjouter" styleClass="button, btn-create" text="+ Nouveau" />
                        <Button onAction="#ConsulterRDV" styleClass="button, btn-save" text="Rendez-vous" />
                    </HBox>

                    <!-- Ligne 2 : recherche + filtres + tri (cachée quand on est dans un formulaire) -->
                    <HBox fx:id="searchBar" alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #fdf5f8; -fx-padding: 8 24 10 24;                                  -fx-border-color: transparent transparent #f0e0e8 transparent;">

                        <!-- Recherche texte libre -->
                        <TextField fx:id="tfRecherche" promptText="🔍  Rechercher (diagnostic, contenu...)" style="-fx-pref-width: 260; -fx-pref-height: 36;                                           -fx-font-size: 13px; -fx-background-color: white;                                           -fx-border-color: #e5b7c4; -fx-border-radius: 8;                                           -fx-background-radius: 8;" />

                        <!-- Filtre confidentiel -->
                        <ComboBox fx:id="cbFiltreConfidentiel" promptText="Confidentialité" style="-fx-pref-width: 160; -fx-pref-height: 36;                                          -fx-font-size: 13px; -fx-background-color: white;                                          -fx-border-color: #e5b7c4; -fx-border-radius: 8;                                          -fx-background-radius: 8;" />

                        <!-- Filtre prochain RDV -->
                        <ComboBox fx:id="cbFiltreRdv" promptText="Prochain RDV" style="-fx-pref-width: 160; -fx-pref-height: 36;                                          -fx-font-size: 13px; -fx-background-color: white;                                          -fx-border-color: #e5b7c4; -fx-border-radius: 8;                                          -fx-background-radius: 8;" />

                        <!-- Tri -->
                        <ComboBox fx:id="cbTri" promptText="Trier par..." style="-fx-pref-width: 180; -fx-pref-height: 36;                                          -fx-font-size: 13px; -fx-background-color: white;                                          -fx-border-color: #e5b7c4; -fx-border-radius: 8;                                          -fx-background-radius: 8;" />

                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Compteur résultats -->
                        <Label fx:id="lblCount" style="-fx-font-size: 12px; -fx-text-fill: #999;                                       -fx-font-style: italic;" />

                        <!-- Reset filtres -->
                        <Button onAction="#handleResetFiltres" style="-fx-background-color: transparent; -fx-text-fill: #7a002f;                                        -fx-font-size: 12px; -fx-cursor: hand;                                        -fx-border-color: #e5b7c4; -fx-border-radius: 6;                                        -fx-background-radius: 6; -fx-padding: 4 10;" text="✕ Réinitialiser" />
                    </HBox>

                </VBox>
            </top>

            <!-- CENTER : swappé entre cardsView et le formulaire -->
            <center>
                <!-- Vue par défaut : la grille de cartes -->
                <ScrollPane fx:id="cardsScrollPane" fitToWidth="true" styleClass="list-view">
                    <VBox fx:id="cardsContainer" spacing="12" styleClass="page">
                        <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                    </VBox>
                </ScrollPane>
            </center>

        </BorderPane>
    </center>
</BorderPane>
