<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="580" prefWidth="480" spacing="0" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controlers.ModifierCompteRenduController">

    <stylesheets>
        <URL value="@../styles/style.css" />
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to bottom,#7a002f,#99003d); -fx-padding: 18 24;">
        <Label style="-fx-font-size: 24px;" styleClass="sidebar-title" text="Modifier Compte Rendu" />
    </HBox>

    <!-- Form wrapped in ScrollPane -->
    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" styleClass="list-view" VBox.vgrow="ALWAYS">
        <VBox styleClass="page">
            <VBox spacing="16" styleClass="form-card">

                <!-- Diagnostic -->
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" styleClass="label" text="Diagnostic" />
                    <TextField fx:id="tfDiagnostic" promptText="Diagnostic médical" styleClass="text-field" />
                </VBox>

                <!-- Contenu -->
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" styleClass="label" text="Contenu" />
                    <TextArea fx:id="taContenu" prefRowCount="3" promptText="Contenu du compte rendu..." style="-fx-font-size: 14px; -fx-background-color: white;                                      -fx-border-color: #e5b7c4; -fx-border-radius: 10;                                      -fx-background-radius: 10; -fx-font-family: 'Segoe UI';" />
                </VBox>

                <!-- Traitement -->
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" styleClass="label" text="Traitement" />
                    <TextArea fx:id="taTraitement" prefRowCount="3" promptText="Traitement prescrit..." style="-fx-font-size: 14px; -fx-background-color: white;                                      -fx-border-color: #e5b7c4; -fx-border-radius: 10;                                      -fx-background-radius: 10; -fx-font-family: 'Segoe UI';" />
                </VBox>

                <!-- Prochain RDV -->
                <VBox spacing="5">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" styleClass="label" text="Prochain RDV" />
                    <DatePicker fx:id="dpProchainRdv" style="-fx-pref-width: 220; -fx-pref-height: 42; -fx-font-size: 14px;                                        -fx-background-color: white; -fx-border-color: #e5b7c4;                                        -fx-border-radius: 10; -fx-background-radius: 10;" />
                </VBox>

                <!-- Confidentiel -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" styleClass="label" text="Confidentiel" />
                    <CheckBox fx:id="cbConfidentiel" style="-fx-font-size: 14px;" />
                </HBox>

            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-background-color: white; -fx-padding: 12 24;                  -fx-border-color: #ececec transparent transparent transparent;">
        <Button onAction="#handleAnnuler" styleClass="button, btn-cancel" text="Annuler" />
        <Button onAction="#handleEnregistrer" styleClass="button, btn-save" text="Enregistrer" />
    </HBox>

</VBox>
