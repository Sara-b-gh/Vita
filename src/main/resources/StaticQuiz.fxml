<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="900.0"
            style="-fx-background-color: #f8f5f7;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="15"
              style="-fx-background-color: #AD1457;">

            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Dashboard Quiz"
                   style="-fx-text-fill: white;
                          -fx-font-size: 20px;
                          -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="New Quiz"
                    style="-fx-background-color: white;
                           -fx-text-fill: #AD1457;
                           -fx-background-radius: 8;"
                    prefWidth="130"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <HBox spacing="20">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- LEFT PANEL -->
            <VBox spacing="15" prefWidth="520"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-border-color: #E0E0E0;
                         -fx-border-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Quiz Information"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #AD1457;"/>

                <TextField fx:id="txtSearchQuiz"
                           promptText="Search quiz..."
                           style="-fx-background-color: #f8f5f7;
                                  -fx-border-color: #AD1457;"/>

                <Separator/>

                <HBox spacing="15">
                    <Label text="Quiz ID" prefWidth="120"/>
                    <TextField fx:id="txtQuizId" prefWidth="300"/>
                </HBox>

                <HBox spacing="15">
                    <Label text="Title" prefWidth="120"/>
                    <TextField fx:id="txtTitre" prefWidth="300"/>
                </HBox>

                <HBox spacing="15">
                    <Label text="Category" prefWidth="120"/>
                    <ComboBox fx:id="comboCategorie" prefWidth="300"
                              promptText="Choose category"/>
                </HBox>

                <HBox spacing="15">
                    <Label text="Difficulty" prefWidth="120"/>
                    <ComboBox fx:id="comboDifficulte" prefWidth="300"
                              promptText="Choose difficulty"/>
                </HBox>

                <HBox spacing="15">
                    <Label text="Questions" prefWidth="120"/>
                    <TextField fx:id="txtNbQuestions" prefWidth="150"/>
                </HBox>

                <CheckBox fx:id="checkActive" text="Active quiz"/>

                <Separator/>

                <!-- BUTTONS -->
                <HBox spacing="10" alignment="CENTER">

                    <Button text="View Questions"
                            style="-fx-background-color: #AD1457;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>

                    <Button text="Start Quiz"
                            style="-fx-background-color: #6A1B9A;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>

                    <Button text="Results"
                            style="-fx-background-color: #C2185B;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>

                    <Button text="Delete"
                            style="-fx-background-color: #E0E0E0;
                                   -fx-background-radius: 8;"/>

                </HBox>

            </VBox>

            <!-- RIGHT PANEL -->
            <VBox spacing="15" prefWidth="300"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-border-color: #E0E0E0;
                         -fx-border-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">

                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Statistics"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #AD1457;"/>

                <!-- CARD -->
                <VBox spacing="5"
                      style="-fx-background-color: #f8f5f7;
                             -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0;
                             -fx-border-radius: 10;">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="Total Quizzes"/>
                    <Label fx:id="lblTotalQuiz" text="12"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #AD1457;"/>
                </VBox>

                <VBox spacing="5"
                      style="-fx-background-color: #f8f5f7;
                             -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0;
                             -fx-border-radius: 10;">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="Active Quizzes"/>
                    <Label fx:id="lblQuizActifs" text="8"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #6A1B9A;"/>
                </VBox>

                <VBox spacing="5"
                      style="-fx-background-color: #f8f5f7;
                             -fx-background-radius: 10;
                             -fx-border-color: #E0E0E0;
                             -fx-border-radius: 10;">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                    <Label text="Average Score"/>
                    <Label fx:id="lblScoreMoyen" text="75%"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #C2185B;"/>
                </VBox>

                <Separator/>

                <Label text="Tip of the day"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #AD1457;"/>

                <Label wrapText="true"
                       text="Short quizzes (5–10 questions) improve learning efficiency and reduce stress."
                       style="-fx-text-fill: #555555;"/>

            </VBox>

        </HBox>
    </center>

</BorderPane>