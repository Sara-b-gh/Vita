<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vita.devora.Controllers.CommunityViewController">
    <stylesheets>
        <String fx:value="@style.css" />
    </stylesheets>

    <!-- LEFT SIDEBAR -->
    <!-- LEFT SIDEBAR -->
    <left>
        <AnchorPane prefWidth="200.0" style="-fx-background-color: linear-gradient(to bottom,#7a002f,#99003d);">
            <children>
                <!-- Logo area -->
                <Rectangle arcHeight="15.0" arcWidth="15.0" fill="WHITE" height="83.0" layoutX="18.0" layoutY="18.0" opacity="0.42" stroke="WHITE" width="86.0"/>
                <Label layoutX="110.0" layoutY="27.0" text="VITA" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="30.0"/></font>
                </Label>

                <Separator layoutX="5.0" layoutY="114.0" prefWidth="190.0" style="-fx-opacity: 0.3;"/>

                <!-- Navigation -->
                <VBox AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" layoutY="130.0" spacing="5.0">
                    <children>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-cursor: hand;" styleClass="nav-item" text="Tableau de bord" textFill="#fff4f1">
                            <font><Font name="Berlin Sans FB" size="15.0"/></font>
                            <padding><Insets bottom="10" left="20" top="10"/></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-cursor: hand;" styleClass="nav-item" text="Espace Docteurs" textFill="#fff4f1">
                            <font><Font name="Berlin Sans FB" size="15.0"/></font>
                            <padding><Insets bottom="10" left="20" top="10"/></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" prefHeight="40.0" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 0 20 20 0; -fx-cursor: hand;" text="Communauté" textFill="WHITE">
                            <font><Font name="Berlin Sans FB" size="15.0"/></font>
                            <padding><Insets left="20"/></padding>
                        </Button>
                    </children>
                </VBox>

                <VBox AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" spacing="10.0">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Separator opacity="0.2"/>
                        <Button alignment="BASELINE_LEFT" fx:id="sidebarLogoutBtn" maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #ffcfcf; -fx-cursor: hand;" text="⮑ Déconnexion">
                            <font><Font name="Berlin Sans FB" size="15.0"/></font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F8F9FA; -fx-border-color: transparent;">
            <content>
                <VBox spacing="0" style="-fx-background-color: #F8F9FA;">

                    <!-- PAGE HEADER & CONTROLS -->
                    <VBox style="-fx-background-color: white;">
                        <padding><Insets bottom="25" left="28" right="28" top="25"/></padding>
                        <HBox alignment="CENTER_LEFT">
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Panel de Modération"/>
                                <Label style="-fx-text-fill: #636E72;" text="Vous avez le contrôle total sur les publications et commentaires."/>
                            </VBox>

                            <!-- Search and Filter in Header -->
                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <ComboBox fx:id="categoryFilter" prefWidth="150.0" promptText="Catégorie" style="-fx-background-radius: 20;"/>
                                <TextField fx:id="searchField" prefWidth="250" promptText="Rechercher..." style="-fx-background-radius: 20;"/>
                            </HBox>
                        </HBox>
                    </VBox>

                    <!-- STATS CARDS -->
                    <HBox spacing="20" style="-fx-padding: 25 28 0 28;">
                        <VBox HBox.hgrow="ALWAYS" fx:id="cardPublications" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" styleClass="stat-card">
                            <Label style="-fx-text-fill: #636E72;" text="Publications Globales"/>
                            <Label fx:id="totalPublications" style="-fx-font-size: 32; -fx-font-weight: bold;" text="--"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" fx:id="cardCommentaires" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" styleClass="stat-card">
                            <Label style="-fx-text-fill: #636E72;" text="Commentaires &amp; Réponses"/>
                            <Label fx:id="totalCommentaires" style="-fx-font-size: 32; -fx-font-weight: bold;" text="--"/>
                        </VBox>
                    </HBox>

                    <!-- MAIN TABLE -->
                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);">
                        <VBox.margin><Insets bottom="30" left="28" right="28" top="25"/></VBox.margin>

                        <HBox alignment="CENTER_LEFT">
                            <Label fx:id="postCountLabel" style="-fx-font-size: 18; -fx-font-weight: bold;" text="Flux de la Communauté (0)"/>
                        </HBox>

                        <Separator/>

                        <!-- TABLE HEADERS -->
                        <HBox style="-fx-background-color: #F8F9FA; -fx-padding: 12; -fx-background-radius: 5;">
                            <Label text="CONTENU" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                            <Label text="CATÉGORIE" prefWidth="120" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                            <Label text="AUTEUR" prefWidth="150" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                            <Label text="DATE" prefWidth="120" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                            <Label text="INTERACTION" prefWidth="100" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                            <Label text="MODÉRER" prefWidth="100" alignment="CENTER" style="-fx-font-weight: bold; -fx-text-fill: #8a0037;" />
                        </HBox>

                        <!-- CONTAINER FOR DYNAMIC ROWS -->
                        <VBox fx:id="postsContainer" spacing="2"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
