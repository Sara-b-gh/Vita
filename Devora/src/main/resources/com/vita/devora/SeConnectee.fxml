<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      prefWidth="900" prefHeight="600"
      style="-fx-background-color: #ffffff;">

    <!-- ===== LEFT PANEL ===== -->
    <StackPane prefWidth="400" prefHeight="600">
        <Pane style="-fx-background-color: linear-gradient(to bottom right, #ff6b81, #ff4757);" />

        <!-- Decorative circles -->
        <Circle radius="180" layoutX="50" layoutY="80" fill="rgba(255,255,255,0.06)" />
        <Circle radius="120" layoutX="350" layoutY="500" fill="rgba(255,255,255,0.07)" />
        <Circle radius="60"  layoutX="300" layoutY="100" fill="rgba(255,255,255,0.08)" />

        <VBox alignment="TOP_LEFT">
            <padding><Insets top="50" left="40" right="40" bottom="40"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="14">
                <StackPane prefWidth="58" prefHeight="58"
                           style="-fx-background-color: white; -fx-background-radius: 14;">
                    <Label text="🏥" style="-fx-font-size: 26px;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Gestion Hospitalière"
                           style="-fx-font-size: 19px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label text="Système de gestion intégré"
                           style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.82);"/>
                </VBox>
            </HBox>

            <Region prefHeight="40"/>

            <Label text="Fonctionnalités principales"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>

            <Region prefHeight="20"/>

            <VBox spacing="10">
                <Label text="📅 Gestion des rendez-vous"
                       style="-fx-text-fill: white;"/>
                <Label text="📋 Dossiers médicaux"
                       style="-fx-text-fill: white;"/>
                <Label text="📊 Statistiques"
                       style="-fx-text-fill: white;"/>
                <Label text="💡 Interface moderne"
                       style="-fx-text-fill: white;"/>
            </VBox>
        </VBox>
    </StackPane>

    <!-- ===== RIGHT PANEL ===== -->
    <VBox prefWidth="500" alignment="CENTER">
        <padding><Insets top="50" left="60" right="60" bottom="40"/></padding>

        <!-- Title -->
        <Label text="Connexion"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ff4757;"/>

        <Region prefHeight="10"/>

        <Label text="Entrez vos identifiants"
               style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>

        <Region prefHeight="30"/>

        <!-- Email -->
        <Label text="Email"/>
        <TextField promptText="email@exemple.com" />

        <Region prefHeight="20"/>

        <!-- Password -->
        <Label text="Mot de passe"/>
        <PasswordField promptText="********"/>

        <Region prefHeight="20"/>

        <!-- Button -->
        <Button text="Se connecter"
                prefHeight="40"
                maxWidth="Infinity"
                style="-fx-background-color: #ff4757; -fx-text-fill: white;"/>

        <Region prefHeight="20"/>

        <!-- Link -->
        <Hyperlink text="Créer un compte"/>
    </VBox>

</HBox>