<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<HBox prefHeight="680" prefWidth="1100" style="-fx-background-color: #030B16;" styleClass="root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.medpulse.LoginController">

    <!-- ═══════════════════════════════════════ -->
    <!--              LEFT PANEL                 -->
    <!-- ═══════════════════════════════════════ -->
    <VBox prefWidth="620" spacing="0" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #061525, #0A2040, #0D2E58);                  -fx-padding: 52 48 52 48;">

        <!-- LOGO -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane prefHeight="44" prefWidth="44" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #00A8FF, #00D2AA);                               -fx-background-radius: 11;">
                <!-- Croix médicale -->
                <VBox alignment="CENTER" spacing="0">
                    <Rectangle arcHeight="2" arcWidth="2" fill="white" height="20" width="4" />
                </VBox>
                <HBox alignment="CENTER" spacing="0">
                    <Rectangle arcHeight="2" arcWidth="2" fill="white" height="4" width="20" />
                </HBox>
            </StackPane>
            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="Med" />
                <Label style="-fx-text-fill: #00A8FF; -fx-font-size: 20; -fx-font-weight: bold;" text="Pulse" />
                <Label style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text=" Pro" />
            </HBox>
        </HBox>

        <Region prefHeight="40" />

        <!-- BADGE TAG -->
        <HBox alignment="CENTER_LEFT" maxWidth="280" spacing="8" style="-fx-background-color: rgba(0,168,255,0.1);                      -fx-border-color: rgba(0,168,255,0.25);                      -fx-border-radius: 20;                      -fx-background-radius: 20;                      -fx-padding: 5 14 5 10;">
            <Circle fill="#00A8FF" radius="4" />
            <Label style="-fx-text-fill: #00A8FF; -fx-font-size: 12;" text="Plateforme Hospitalière Intégrée" />
        </HBox>

        <Region prefHeight="16" />

        <!-- MAIN HEADING -->
        <VBox spacing="4">
            <Label style="-fx-text-fill: white; -fx-font-size: 38; -fx-font-weight: bold;" text="La santé," />
            <Label style="-fx-text-fill: #00A8FF; -fx-font-size: 38; -fx-font-weight: bold;" text="réinventée" />
            <Label style="-fx-text-fill: white; -fx-font-size: 38; -fx-font-weight: bold;" text="numériquement." />
        </VBox>

        <Region prefHeight="36" />

        <!-- FEATURES -->
        <VBox spacing="10">

            <!-- Feature 1 -->
            <HBox alignment="CENTER_LEFT" spacing="13" style="-fx-background-color: rgba(255,255,255,0.035);                          -fx-border-color: rgba(255,255,255,0.065);                          -fx-border-radius: 13;                          -fx-background-radius: 13;                          -fx-padding: 14 16 14 16;">
                <StackPane prefHeight="34" prefWidth="34" style="-fx-background-color: rgba(0,168,255,0.15);                                   -fx-background-radius: 9;">
                    <Label style="-fx-font-size: 16;" text="🏥" />
                </StackPane>
                <VBox spacing="3">
                    <Label style="-fx-text-fill: rgba(255,255,255,0.88); -fx-font-size: 13; -fx-font-weight: bold;" text="Dossiers patients unifiés" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.42); -fx-font-size: 11;" text="Historique médical en temps réel." />
                </VBox>
            </HBox>

            <!-- Feature 2 -->
            <HBox alignment="CENTER_LEFT" spacing="13" style="-fx-background-color: rgba(255,255,255,0.035);                          -fx-border-color: rgba(255,255,255,0.065);                          -fx-border-radius: 13;                          -fx-background-radius: 13;                          -fx-padding: 14 16 14 16;">
                <StackPane prefHeight="34" prefWidth="34" style="-fx-background-color: rgba(0,210,170,0.15);                                   -fx-background-radius: 9;">
                    <Label style="-fx-font-size: 16;" text="📋" />
                </StackPane>
                <VBox spacing="3">
                    <Label style="-fx-text-fill: rgba(255,255,255,0.88); -fx-font-size: 13; -fx-font-weight: bold;" text="Planification intelligente" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.42); -fx-font-size: 11;" text="Plannings et ressources centralisés." />
                </VBox>
            </HBox>

            <!-- Feature 3 -->
            <HBox alignment="CENTER_LEFT" spacing="13" style="-fx-background-color: rgba(255,255,255,0.035);                          -fx-border-color: rgba(255,255,255,0.065);                          -fx-border-radius: 13;                          -fx-background-radius: 13;                          -fx-padding: 14 16 14 16;">
                <StackPane prefHeight="34" prefWidth="34" style="-fx-background-color: rgba(130,100,255,0.15);                                   -fx-background-radius: 9;">
                    <Label style="-fx-font-size: 16;" text="📊" />
                </StackPane>
                <VBox spacing="3">
                    <Label style="-fx-text-fill: rgba(255,255,255,0.88); -fx-font-size: 13; -fx-font-weight: bold;" text="Analyses &amp; rapports" />
                    <Label style="-fx-text-fill: rgba(255,255,255,0.42); -fx-font-size: 11;" text="Pilotez la performance en un coup d'œil." />
                </VBox>
            </HBox>

        </VBox>

        <Region prefHeight="32" />

        <!-- STATS ROW -->
        <HBox alignment="CENTER_LEFT" spacing="0">

            <VBox spacing="4">
                <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="98%" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;" text="Disponibilité système" />
            </VBox>

            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="450+" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;" text="Hôpitaux partenaires" />
            </VBox>

            <VBox spacing="4">
                <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="2.3M" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 11;" text="Patients suivis" />
            </VBox>

        </HBox>

    </VBox>

    <!-- ═══════════════════════════════════════ -->
    <!--              RIGHT PANEL                -->
    <!-- ═══════════════════════════════════════ -->
    <VBox alignment="CENTER_LEFT" prefWidth="480" spacing="0" style="-fx-background-color: #050D1A;                  -fx-padding: 52 46 52 46;" HBox.hgrow="ALWAYS">

        <!-- WELCOME -->
        <Label style="-fx-text-fill: rgba(255,255,255,0.3);                       -fx-font-size: 11;                       -fx-letter-spacing: 2;" text="ESPACE SÉCURISÉ" />
        <Region prefHeight="8" />
        <Label style="-fx-text-fill: white; -fx-font-size: 27; -fx-font-weight: bold;" text="Connexion à votre" />
        <Label style="-fx-text-fill: white; -fx-font-size: 27; -fx-font-weight: bold;" text="espace de travail" />
        <Region prefHeight="10" />
        <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 13;" text="Accédez à votre tableau de bord personnalisé." />

        <Region prefHeight="28" />

        <!-- IDENTIFIANT FIELD -->
        <Label style="-fx-text-fill: rgba(255,255,255,0.48);                       -fx-font-size: 11;                       -fx-font-weight: bold;" text="IDENTIFIANT" />
        <Region prefHeight="8" />
        <TextField fx:id="usernameField" maxWidth="Infinity" prefHeight="46" promptText="dr.dupont@hopital.fr" style="-fx-background-color: rgba(255,255,255,0.05);                           -fx-border-color: rgba(255,255,255,0.1);                           -fx-border-radius: 11;                           -fx-background-radius: 11;                           -fx-text-fill: white;                           -fx-prompt-text-fill: rgba(255,255,255,0.2);                           -fx-font-size: 14;                           -fx-padding: 13 14 13 14;" />

        <Region prefHeight="16" />

        <!-- MOT DE PASSE FIELD -->
        <Label style="-fx-text-fill: rgba(255,255,255,0.48);                       -fx-font-size: 11;                       -fx-font-weight: bold;" text="MOT DE PASSE" />
        <Region prefHeight="8" />
        <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="46" promptText="••••••••••" style="-fx-background-color: rgba(255,255,255,0.05);                               -fx-border-color: rgba(255,255,255,0.1);                               -fx-border-radius: 11;                               -fx-background-radius: 11;                               -fx-text-fill: white;                               -fx-prompt-text-fill: rgba(255,255,255,0.2);                               -fx-font-size: 14;                               -fx-padding: 13 14 13 14;" />

        <Region prefHeight="16" />

        <!-- OPTIONS ROW -->
        <HBox alignment="CENTER_LEFT" spacing="0">
            <CheckBox fx:id="rememberCheck" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 13;" text="Rester connecté" />
            <Region HBox.hgrow="ALWAYS" />
            <Hyperlink fx:id="forgotLink" onAction="#handleForgotPassword" style="-fx-text-fill: #00A8FF; -fx-font-size: 13; -fx-border-color: transparent;" text="Mot de passe oublié ?" />
        </HBox>

        <Region prefHeight="22" />

        <!-- LOGIN BUTTON -->
        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" prefHeight="48" style="-fx-background-color: linear-gradient(from 0% 0% to 100% 0%, #00A8FF, #00D2AA);                        -fx-text-fill: white;                        -fx-font-size: 15;                        -fx-font-weight: bold;                        -fx-background-radius: 11;                        -fx-cursor: hand;" text="Accéder à la plateforme →" />

        <Region prefHeight="18" />

        <!-- SEPARATOR -->
        <HBox alignment="CENTER" spacing="12">
            <Separator HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: rgba(255,255,255,0.22); -fx-font-size: 11;" text="ouour créer un compte " />
            <Separator HBox.hgrow="ALWAYS" />
        </HBox>

        <Region prefHeight="16" />

        <!-- SSO BUTTON -->
        <Button fx:id="ssoButton" maxWidth="Infinity" onAction="#handleSSO" prefHeight="44" style="-fx-background-color: rgba(255,255,255,0.04);                        -fx-border-color: rgba(255,255,255,0.1);                        -fx-border-radius: 11;                        -fx-background-radius: 11;                        -fx-text-fill: rgba(255,255,255,0.55);                        -fx-font-size: 13;                        -fx-cursor: hand;" text=" Contactez l’administrateur" />

        <Region prefHeight="20" />

        <!-- FOOTER -->
        <Separator style="-fx-background-color: rgba(255,255,255,0.06);" />
        <Region prefHeight="16" />
        <HBox alignment="CENTER_LEFT">
            <Label style="-fx-text-fill: rgba(255,255,255,0.28); -fx-font-size: 11;" text="🔒  Copyrights : Devora " />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: rgba(255,255,255,0.15); -fx-font-size: 11;" text="v4.2.1 · 2026" />
        </HBox>

    </VBox>

</HBox>
