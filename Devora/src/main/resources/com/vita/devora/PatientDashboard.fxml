<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vita.devora.Controlleurs.PatientDashboardController">
    <stylesheets>
        <URL value="@STYLE1.css" />
    </stylesheets>

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <left>
        <AnchorPane prefHeight="720.0" prefWidth="237.0" styleClass="dashboard-sidebar" BorderPane.alignment="CENTER">
            <children>
                <Separator layoutX="5.0" layoutY="114.0" prefHeight="26.0" prefWidth="224.0" />
                <Button layoutX="36.0" layoutY="155.0" onAction="#handlePatDash" style="-fx-background-color: transparent;" styleClass="nav-item" text="Tableau de bord" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Button layoutX="50.0" layoutY="201.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Mon Dossier" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Button layoutX="46.0" layoutY="244.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Rendez-vous" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Button layoutX="50.0" layoutY="287.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Événements" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Button layoutX="56.0" layoutY="331.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Formulaire" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Button layoutX="77.0" layoutY="375.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Quiz" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>
                <Rectangle arcHeight="15.0" arcWidth="15.0" fill="WHITE" height="83.0" layoutX="18.0" layoutY="18.0" opacity="0.42" stroke="WHITE" strokeDashOffset="50.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeMiterLimit="70.0" strokeType="INSIDE" width="86.0" />
                <ImageView fitHeight="127.0" fitWidth="116.0" layoutX="13.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../../../image/logo.png" /></image>
                </ImageView>
                <Label layoutX="110.0" layoutY="27.0" prefHeight="50.0" prefWidth="126.0" text="VITA" textAlignment="CENTER" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="36.0" /></font>
                </Label>
                <Button fx:id="ProfilBtn" layoutX="58.0" layoutY="456.0" onAction="#handleProfile" style="-fx-background-color: transparent;" styleClass="nav-item" text="Mon Profil" textFill="#fff4f1">
                    <font>
                        <Font name="Berlin Sans FB" size="18.0" />
                    </font>
                </Button>
                <Button layoutX="45.0" layoutY="415.0" mnemonicParsing="false" style="-fx-background-color: transparent;" styleClass="nav-item" text="Communauté" textFill="#fff4f1">
                    <font>
                        <Font name="Berlin Sans FB" size="18.0" />
                    </font>
                </Button>
            </children>
        </AnchorPane>
    </left>

    <!-- ═══════════════ CONTENU PRINCIPAL ═══════════════ -->
    <center>
        <AnchorPane styleClass="dashboard-content" BorderPane.alignment="CENTER">
            <children>

                <!-- Compteur Total patients -->
                <AnchorPane layoutX="680.0" layoutY="153.0" prefHeight="66.0" prefWidth="96.0" styleClass="stat-card">
                    <Label layoutX="9.0" layoutY="6.0" text="Mes Rendez_vous" textAlignment="CENTER" textFill="#636E72">
                        <font><Font name="Berlin Sans FB" size="11.0" /></font>
                    </Label>
                    <Label fx:id="totalPatientsLabel" layoutX="45.0" layoutY="23.0" styleClass="stat-number" text="0" />
                </AnchorPane>

                <!-- Titre -->
                <Label layoutX="19.0" layoutY="9.0" prefHeight="44.0" prefWidth="316.0" text="Tableau de bord Patient">
                    <font><Font name="Berlin Sans FB" size="24.0" /></font>
                </Label>
                <Label fx:id="welcomeLabel" layoutX="19.0" layoutY="54.0" text="Bienvenue" textFill="#636E72">
                    <font><Font name="Berlin Sans FB" size="13.0" /></font>
                </Label>

                <!-- Ligne séparatrice -->
                <Line endX="953.0" layoutX="19.0" layoutY="76.0" stroke="#8a0037" strokeWidth="2.0" />

                <!-- Bouton Déconnexion -->
                <Button fx:id="logoutBtn" layoutX="870.0" layoutY="14.0" onAction="#handleLogout" prefHeight="37.0" prefWidth="150.0" styleClass="logout-btn" text="Déconnexion" textFill="#8a0037">
                    <font><Font name="Berlin Sans FB" size="16.0" /></font>
                </Button>

                <!-- Table des patients -->
                <ScrollPane layoutX="145.0" layoutY="261.0" prefHeight="439.0" prefWidth="774.0">
                    <content>
                        <FlowPane fx:id="patientCardsPane" hgap="16.0" prefHeight="0.0" prefWidth="972.0" prefWrapLength="980.0" styleClass="cards-pane" vgap="16.0" />
                    </content>
                </ScrollPane>
            <TextField fx:id="searchField" layoutX="141.0" layoutY="140.0" prefHeight="36.0" prefWidth="403.0" promptText="search_RV" styleClass="search-field" />



            </children>
        </AnchorPane>
    </center>

</BorderPane>
