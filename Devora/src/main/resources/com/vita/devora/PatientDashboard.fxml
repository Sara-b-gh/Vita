<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vita.devora.Controlleurs.PatientDashboardController">
    <stylesheets>
        <URL value="@STYLE1.css" />
    </stylesheets>

    <left>
        <AnchorPane prefHeight="720.0" prefWidth="237.0" styleClass="dashboard-sidebar" BorderPane.alignment="CENTER">
            <children>
                <Separator layoutX="5.0" layoutY="114.0" prefHeight="26.0" prefWidth="224.0" />

                <Button layoutX="36.0" layoutY="155.0" onAction="#handlePatDash" style="-fx-background-color: transparent;" styleClass="nav-item nav-item-active" text="Tableau de bord" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="51.0" layoutY="201.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Rendez-vous" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="52.0" layoutY="247.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Événements" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="78.0" layoutY="293.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Quiz" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="48.0" layoutY="339.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Communauté" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="57.0" layoutY="385.0" style="-fx-background-color: transparent;" styleClass="nav-item" text="Formulaire" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Button layoutX="60.0" layoutY="431.0" onAction="#handleProfile" style="-fx-background-color: transparent;" styleClass="nav-item" text="Mon Profil" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Button>

                <Rectangle arcHeight="15.0" arcWidth="15.0" fill="WHITE" height="83.0" layoutX="18.0" layoutY="18.0" opacity="0.42" stroke="WHITE" strokeDashOffset="50.0" strokeLineCap="ROUND" strokeLineJoin="ROUND" strokeMiterLimit="70.0" strokeType="INSIDE" width="86.0" />
                <ImageView fitHeight="127.0" fitWidth="116.0" layoutX="13.0" pickOnBounds="true" preserveRatio="true">
                    <image><Image url="@../../../image/logo.png" /></image>
                </ImageView>
                <Label layoutX="110.0" layoutY="27.0" prefHeight="50.0" prefWidth="126.0" text="VITA" textAlignment="CENTER" textFill="#fff4f1">
                    <font><Font name="Berlin Sans FB" size="36.0" /></font>
                </Label>

                <Button layoutX="42.0" layoutY="654.0" onAction="#handleLogout" prefHeight="37.0" prefWidth="150.0" style="-fx-background-color: #fff4f1;" styleClass="logout-btn" text="Deconnexion" textFill="#8a0037">
                    <font><Font name="Berlin Sans FB" size="16.0" /></font>
                </Button>
            </children>
        </AnchorPane>
    </left>

    <center>
        <AnchorPane styleClass="dashboard-content" BorderPane.alignment="CENTER">
            <children>

                <!-- Titre -->
                <Label layoutX="19.0" layoutY="9.0" prefHeight="44.0" prefWidth="400.0" text="Tableau de bord Patient">
                    <font><Font name="Berlin Sans FB" size="24.0" /></font>
                </Label>
                <Label fx:id="welcomeLabel" layoutX="19.0" layoutY="54.0" text="Bienvenue" textFill="#636E72">
                    <font><Font name="Berlin Sans FB" size="13.0" /></font>
                </Label>

                <!-- Ligne séparatrice -->
                <Line endX="953.0" layoutX="19.0" layoutY="76.0" stroke="#8a0037" strokeWidth="2.0" />

                <!-- Titre WHO -->
                <Label layoutX="19.0" layoutY="90.0" text="🌐 Statistiques Mondiales de Santé (WHO)" textFill="#8a0037">
                    <font><Font name="Berlin Sans FB" size="18.0" /></font>
                </Label>

                <!-- Loading Label -->
                <Label fx:id="loadingLabel" layoutX="700.0" layoutY="93.0" text="" textFill="#636E72">
                    <font><Font name="Berlin Sans FB" size="13.0" /></font>
                </Label>

                <!-- ScrollPane pour les stats WHO -->
                <ScrollPane fitToWidth="true" layoutX="19.0" layoutY="125.0" prefHeight="565.0" prefWidth="960.0">
                    <content>
                        <VBox fx:id="whoContainer" spacing="12.0" style="-fx-padding: 10;">
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </AnchorPane>
    </center>

</BorderPane>
