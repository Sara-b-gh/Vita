<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="720.0" prefWidth="1280.0"
            styleClass="dashboard-root"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vita.devora.Controlleurs.DoctorDashboardController">
   <stylesheets>
      <URL value="@STYLE1.css" />
   </stylesheets>

   <left>
      <AnchorPane prefHeight="720.0" prefWidth="237.0" styleClass="dashboard-sidebar" BorderPane.alignment="CENTER">
         <children>
            <Separator layoutX="5.0" layoutY="114.0" prefHeight="26.0" prefWidth="224.0" />

            <!-- Tableau de bord → ACTIF -->
            <Button fx:id="dashBtn" layoutX="36.0" layoutY="155.0"
                    onAction="#haddleDashbordDocteur"
                    styleClass="nav-item nav-item-active"
                    text="Tableau de bord" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Mes Patients -->
            <Button layoutX="52.0" layoutY="201.0"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Mes Patients" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Rendez-vous -->
            <Button layoutX="51.0" layoutY="247.0"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Rendez-vous" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Événements -->
            <Button layoutX="52.0" layoutY="293.0"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Événements" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Quiz -->
            <Button layoutX="78.0" layoutY="339.0"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Quiz" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Communauté -->
            <Button layoutX="48.0" layoutY="385.0"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Communauté" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Mon Profil -->
            <Button fx:id="profileBtn" layoutX="60.0" layoutY="431.0"
                    onAction="#handleProfile"
                    style="-fx-background-color: transparent;"
                    styleClass="nav-item" text="Mon Profil" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Button>

            <!-- Logo -->
            <Rectangle arcHeight="15.0" arcWidth="15.0" fill="WHITE" height="83.0"
                       layoutX="18.0" layoutY="18.0" opacity="0.42" stroke="WHITE"
                       strokeDashOffset="50.0" strokeLineCap="ROUND"
                       strokeLineJoin="ROUND" strokeMiterLimit="70.0"
                       strokeType="INSIDE" width="86.0" />
            <ImageView fitHeight="127.0" fitWidth="116.0" layoutX="13.0"
                       pickOnBounds="true" preserveRatio="true">
               <image><Image url="@../../../image/logo.png" /></image>
            </ImageView>
            <Label layoutX="110.0" layoutY="27.0" prefHeight="50.0" prefWidth="126.0"
                   text="VITA" textAlignment="CENTER" textFill="#fff4f1">
               <font><Font name="Berlin Sans FB" size="36.0" /></font>
            </Label>

            <!-- Déconnexion -->
            <Button fx:id="logoutBtn" layoutX="42.0" layoutY="654.0"
                    onAction="#handleLogout"
                    prefHeight="37.0" prefWidth="150.0"
                    styleClass="logout-btn"
                    text="Deconnexion" textFill="#8a0037">
               <font><Font name="Berlin Sans FB" size="16.0" /></font>
            </Button>

            <!-- FlowPane caché -->
<!--            <FlowPane fx:id="patientCardsPane" layoutX="0.0" layoutY="0.0"-->
<!--                      prefHeight="0.0" prefWidth="0.0" visible="false"/>-->

         </children>
      </AnchorPane>
   </left>

   <center>
      <AnchorPane styleClass="dashboard-content" BorderPane.alignment="CENTER">
         <children>

            <!-- Titre -->
            <Label layoutX="19.0" layoutY="9.0" prefHeight="44.0" prefWidth="400.0"
                   text="Tableau de bord Docteur">
               <font><Font name="Berlin Sans FB" size="24.0" /></font>
            </Label>
            <Label fx:id="welcomeLabel" layoutX="19.0" layoutY="54.0"
                   text="Bienvenue" textFill="#636E72">
               <font><Font name="Berlin Sans FB" size="13.0" /></font>
            </Label>

            <!-- Ligne séparatrice -->
            <Line endX="953.0" layoutX="19.0" layoutY="76.0" stroke="#8a0037" strokeWidth="2.0" />

            <!-- KPI Total Patients -->
            <AnchorPane layoutX="19.0" layoutY="90.0" prefHeight="70.0" prefWidth="160.0" styleClass="stat-card">
               <Label layoutX="12.0" layoutY="8.0" text="Mes Patients" textFill="#636E72">
                  <font><Font name="Berlin Sans FB" size="11.0" /></font>
               </Label>
               <Label fx:id="totalPatientsLabel" layoutX="55.0" layoutY="25.0"
                      styleClass="stat-number" text="0" />
            </AnchorPane>

            <!-- FlowPane caché pour les patients -->
            <FlowPane fx:id="patientCardsPane" layoutX="0.0" layoutY="0.0"
                      prefHeight="0.0" prefWidth="0.0" visible="false"/>

            <!-- Titre News -->
            <Label layoutX="19.0" layoutY="175.0"
                   text="🗞️ Actualités Médicales" textFill="#8a0037">
               <font><Font name="Berlin Sans FB" size="18.0" /></font>
            </Label>

            <!-- Loading Label -->
            <Label fx:id="loadingLabel" layoutX="700.0" layoutY="178.0"
                   text="" textFill="#636E72">
               <font><Font name="Berlin Sans FB" size="13.0" /></font>
            </Label>

            <!-- Barre de recherche -->
            <TextField fx:id="newsSearchField" layoutX="19.0" layoutY="210.0"
                       prefHeight="36.0" prefWidth="400.0"
                       promptText="🔍 Rechercher une actualité médicale..."
                       styleClass="search-field"/>

            <Button layoutX="430.0" layoutY="210.0" prefHeight="36.0" prefWidth="120.0"
                    onAction="#handleNewsSearch"
                    style="-fx-background-color: #8a0037; -fx-text-fill: white; -fx-background-radius: 8;"
                    text="Rechercher">
               <font><Font name="Berlin Sans FB" size="13.0" /></font>
            </Button>

            <Button layoutX="560.0" layoutY="210.0" prefHeight="36.0" prefWidth="80.0"
                    onAction="#handleNewsReset"
                    style="-fx-background-color: transparent; -fx-text-fill: #8a0037; -fx-border-color: #8a0037; -fx-border-radius: 8; -fx-border-width: 1;"
                    text="Reset">
               <font><Font name="Berlin Sans FB" size="13.0" /></font>
            </Button>

            <!-- ScrollPane pour les news -->
            <ScrollPane layoutX="19.0" layoutY="260.0" prefHeight="430.0"
                        prefWidth="960.0" fitToWidth="true">
               <content>
                  <VBox fx:id="newsContainer" spacing="12.0" style="-fx-padding: 10;">
                  </VBox>
               </content>
            </ScrollPane>

         </children>
      </AnchorPane>
   </center>

</BorderPane>