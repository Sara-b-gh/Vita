<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #fff4f1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vita.devora.Controlleurs.User.AddUserController">

   <children>
      <Rectangle arcHeight="50.0" arcWidth="50.0" fill="#a62d5f00" height="275.0" layoutX="76.0" layoutY="55.0" stroke="#e82a6c" strokeType="INSIDE" strokeWidth="2.0" width="452.0" />

      <!-- Titre -->
      <Label layoutX="27.0" layoutY="20.0" text="Ajouter un docteur">
         <font>
            <Font name="Berlin Sans FB" size="20.0" />
         </font>
      </Label>

      <!-- Nom -->
      <Label layoutX="89.0" layoutY="75.0" text="Nom *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font></Label>
      <TextField fx:id="nomField" layoutX="89.0" layoutY="95.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-text-fill: white;" />

      <!-- Prénom -->
      <Label layoutX="323.0" layoutY="75.0" text="Prénom *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font></Label>
      <TextField fx:id="prenomField" layoutX="323.0" layoutY="95.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-text-fill: white;" />

      <!-- Email -->
      <Label layoutX="89.0" layoutY="196.0" text="Email *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font></Label>
      <TextField fx:id="emailField" layoutX="89.0" layoutY="216.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-text-fill: white;" />

      <!-- Téléphone -->
      <Label layoutX="323.0" layoutY="196.0" text="Téléphone *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font></Label>
      <TextField fx:id="telField" layoutX="323.0" layoutY="216.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-text-fill: white;" />

      <!-- Département -->
      <Label layoutX="89.0" layoutY="254.0" text="Département *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font></Label>
      <ComboBox fx:id="departementCombo" layoutX="89.0" layoutY="274.0" prefHeight="34.0" prefWidth="300.0" promptText="Choisir département" style="-fx-background-color: #a82c5e;" />
      <TextField fx:id="cinField" layoutX="92.0" layoutY="156.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-text-fill: white;" />
      <Label layoutX="92.0" layoutY="136.0" text="C.I.N *">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font>
      </Label>
      <Label layoutX="324.0" layoutY="136.0" text="Date de naisssance*">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font>
      </Label>
      <Button layoutX="416.0" layoutY="348.0" onAction="#handleAdd" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #8a0037; -fx-background-radius: 10px;" text="+ Ajouter le docteur" textFill="WHITE">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font>
      </Button>
      <Button cancelButton="true" layoutX="283.0" layoutY="349.0" onAction="#handleCancel" prefHeight="33.0" prefWidth="105.0" style="-fx-background-color: transparent; -fx-border-radius: 10px;                      -fx-border-color: #8a0037; -fx-border-width: 1.5px;" text="Annuler" textFill="#8a0037">
         <font>
            <Font name="Berlin Sans FB" size="14.0" />
         </font>
      </Button>
      <DatePicker fx:id="dobPicker" layoutX="326.0" layoutY="155.0" prefHeight="34.0" prefWidth="162.0" style="-fx-background-color: #a82c5e; -fx-border-color: #a82c5e;" />

   </children>
</AnchorPane>
