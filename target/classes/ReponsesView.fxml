<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controles.ReponsesController"
      spacing="16"
      style="-fx-background-color: #f0f4f9; -fx-padding: 10;">

    <!-- RÉSUMÉ -->
    <HBox spacing="16">
        <VBox spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0; -fx-border-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);
                     -fx-padding: 20;">
            <Label text="Nombre de réponses"
                   style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="lblTotalReponses" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6D1B3A;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0; -fx-border-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);
                     -fx-padding: 20;">
            <Label text="Score moyen"
                   style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="lblScoreMoyen" text="0%"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #AD1457;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 8;
                     -fx-border-color: #e0e0e0; -fx-border-radius: 8;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),6,0,0,2);
                     -fx-padding: 20;">
            <Label text="Participants"
                   style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
            <Label fx:id="lblParticipants" text="0"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        </VBox>
    </HBox>

    <!-- LISTE QUESTIONS + STATS -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox fx:id="boxQuestions" spacing="16"
              style="-fx-padding: 0 4 20 4;"/>
    </ScrollPane>
</VBox>
