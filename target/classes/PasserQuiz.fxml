<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/22"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controles.PasserQuizController"
      style="-fx-background-color: #f0ebf4;">

    <!-- NAVBAR -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #6D1B3A; -fx-padding: 10 20;">
        <Label text="🏥 VitaSanté"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🚪 Déconnexion" onAction="#handleDeconnexion"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-border-color: white; -fx-border-radius: 6;
                       -fx-background-radius: 6; -fx-padding: 6 14;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #f0ebf4; -fx-background: #f0ebf4;">

        <VBox spacing="16" style="-fx-background-color: #f0ebf4;">
            <padding><Insets top="30" bottom="30" left="60" right="60"/></padding>

            <!-- CARTE TITRE -->
            <VBox style="-fx-background-color: white;
                         -fx-background-radius: 10;
                         -fx-border-color: #AD1457 transparent transparent transparent;
                         -fx-border-width: 8 0 0 0;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>
                <Label text="🏥 Quiz VitaSanté"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;
                              -fx-text-fill: #6D1B3A;"/>
                <Label fx:id="lblProgression" text="Question 1 sur N"
                       style="-fx-font-size: 13px; -fx-text-fill: #888;
                              -fx-padding: 4 0 8 0;"/>
                <ProgressBar fx:id="progressBar" maxWidth="Infinity"
                             progress="0"
                             style="-fx-accent: #AD1457;"/>
            </VBox>

            <!-- CARTE QUESTION -->
            <VBox fx:id="questionCard" spacing="16"
                  style="-fx-background-color: white;
                         -fx-background-radius: 10;
                         -fx-border-color: #e0e0e0;
                         -fx-border-radius: 10;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

                <Label fx:id="lblQuestion" text="..."
                       style="-fx-font-size: 18px; -fx-font-weight: bold;
                              -fx-text-fill: #333;"
                       wrapText="true"/>

                <VBox fx:id="reponsesBox" spacing="10"/>
            </VBox>

            <!-- BOUTONS NAVIGATION -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button fx:id="btnPrecedent" text="◀ Précédent"
                        onAction="#precedent"
                        style="-fx-background-color: #E0E0E0;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
                <Button fx:id="btnSuivant" text="Suivant ▶"
                        onAction="#suivant"
                        style="-fx-background-color: #AD1457; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-font-weight: bold;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-padding: 10 20;"/>
            </HBox>

            <!-- CARTE RÉSULTAT -->
            <VBox fx:id="resultatCard" spacing="16" visible="false" managed="false"
                  style="-fx-background-color: white;
                         -fx-background-radius: 10;
                         -fx-border-color: #e0e0e0;
                         -fx-border-radius: 10;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),6,0,0,2);">
                <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

                <Label fx:id="lblScore" text="🏆 Score : 0/0"
                       style="-fx-font-size: 24px; -fx-font-weight: bold;
                              -fx-text-fill: #6D1B3A;"/>
                <Label fx:id="lblMessage" text=""
                       style="-fx-font-size: 16px; -fx-text-fill: #555;"
                       wrapText="true"/>

                <VBox fx:id="detailsBox" spacing="8"/>

                <HBox spacing="12">
                    <Button text="🔄 Recommencer" onAction="#recommencer"
                            style="-fx-background-color: #AD1457; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-padding: 10 20;"/>
                    <Button text="🚪 Déconnexion" onAction="#handleDeconnexion"
                            style="-fx-background-color: #6D1B3A; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-background-radius: 6; -fx-cursor: hand;
                                   -fx-padding: 10 20;"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>